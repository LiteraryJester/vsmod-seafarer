{
    "components": [
        // === First Meeting ===
        {
            "code": "testhasmet",
            "owner": "morgan",
            "type": "condition",
            "variable": "player.hasmetmorgan",
            "isNotValue": "true",
            "thenJumpTo": "firstmeet",
            "elseJumpTo": "welcomeback"
        },
        {
            "code": "firstmeet",
            "owner": "morgan",
            "type": "talk",
            "setVariables": { "player.hasmetmorgan": "true" },
            "text": [{ "value": "seafarer:dialogue-morgan-welcome" }]
        },
        {
            "code": "welcomeback",
            "owner": "morgan",
            "type": "talk",
            "text": [{ "value": "seafarer:dialogue-morgan-welcomeback" }],
            "jumpTo": "main"
        },

        // === Main Menu ===
        {
            "code": "main",
            "owner": "player",
            "type": "talk",
            "text": [
                { "value": "dialogue-name", "jumpTo": "name" },
                { "value": "dialogue-profession", "jumpTo": "profession" },
                { "value": "dialogue-trade", "jumpTo": "trade" },
                { "value": "seafarer:dialogue-morgan-tortuga", "jumpTo": "tortuga" },

                // Mine quest: not yet started
                {
                    "value": "seafarer:dialogue-morgan-ask-rebuilding",
                    "jumpTo": "rebuilding-intro",
                    "conditions": [
                        { "variable": "global.quest-seafarer-morgan-mine-status", "isNotValue": "active" },
                        { "variable": "global.quest-seafarer-morgan-mine-status", "isNotValue": "completed" }
                    ]
                },
                // Mine quest: active
                {
                    "value": "seafarer:dialogue-morgan-ask-rebuilding",
                    "jumpTo": "mine-inprogress",
                    "conditions": [
                        { "variable": "global.quest-seafarer-morgan-mine-status", "isValue": "active" }
                    ]
                },
                // Mine quest: completed
                {
                    "value": "seafarer:dialogue-morgan-ask-rebuilding",
                    "jumpTo": "rebuilding-done",
                    "conditions": [
                        { "variable": "global.quest-seafarer-morgan-mine-status", "isValue": "completed" }
                    ]
                },

                { "value": "seafarer:dialogue-goodbye", "jumpTo": "goodbye" }
            ]
        },
        {
            "code": "name",
            "owner": "morgan",
            "type": "talk",
            "trigger": "revealname",
            "text": [{ "value": "seafarer:dialogue-morgan-name" }],
            "jumpTo": "main"
        },
        {
            "code": "profession",
            "owner": "morgan",
            "type": "talk",
            "text": [{ "value": "seafarer:dialogue-morgan-profession" }],
            "jumpTo": "main"
        },
        {
            "code": "trade",
            "owner": "morgan",
            "trigger": "opentrade"
        },
        {
            "code": "tortuga",
            "owner": "morgan",
            "type": "talk",
            "text": [{ "value": "seafarer:dialogue-morgan-tortuga-lore" }],
            "jumpTo": "main"
        },
        {
            "code": "goodbye",
            "owner": "morgan",
            "type": "talk",
            "text": [{ "value": "seafarer:dialogue-morgan-goodbye" }]
        },

        // =============================================================
        // Quest: Reopen the Mine (morgan-mine)
        // =============================================================
        {
            "code": "rebuilding-intro",
            "owner": "morgan",
            "type": "talk",
            "text": [{ "value": "seafarer:dialogue-morgan-rebuilding-intro" }],
            "jumpTo": "mine-offer"
        },

        {
            "code": "mine-offer",
            "owner": "player",
            "type": "talk",
            "text": [
                { "value": "seafarer:dialogue-morgan-accept-mine", "jumpTo": "mine-start" },
                { "value": "seafarer:dialogue-morgan-not-yet", "jumpTo": "main" }
            ]
        },

        {
            "code": "mine-start",
            "owner": "morgan",
            "type": "talk",
            "trigger": "questStart",
            "triggerdata": { "code": "morgan-mine" },
            "text": [{ "value": "seafarer:dialogue-morgan-mine-start" }],
            "jumpTo": "mine-give-letter"
        },
        {
            "code": "mine-give-letter",
            "owner": "morgan",
            "trigger": "giveitemstack",
            "triggerdata": {
                "type": "item",
                "code": "seafarer:letter-morgan",
                "stacksize": 1
            },
            "jumpTo": "main"
        },

        // Quest In Progress
        {
            "code": "mine-inprogress",
            "owner": "player",
            "type": "talk",
            "text": [
                {
                    "value": "seafarer:dialogue-morgan-have-contract",
                    "jumpTo": "mine-deliver-contract",
                    "conditions": [
                        { "variable": "player.inventory", "isValue": "{type: 'item', code: 'seafarer:signed-contract', stacksize: 1}" }
                    ]
                },
                {
                    "value": "seafarer:dialogue-morgan-lost-letter",
                    "jumpTo": "mine-check-letter",
                    "conditions": [
                        { "variable": "player.inventory", "isNotValue": "{type: 'item', code: 'seafarer:letter-morgan', stacksize: 1}" }
                    ]
                },
                { "value": "seafarer:dialogue-morgan-remind-quest", "jumpTo": "mine-reminder" },
                { "value": "seafarer:dialogue-goodbye", "jumpTo": "goodbye" }
            ]
        },

        {
            "code": "mine-reminder",
            "owner": "morgan",
            "type": "talk",
            "text": [{ "value": "seafarer:dialogue-morgan-mine-reminder" }],
            "jumpTo": "main"
        },

        // Check if player really lost the letter (not just in another slot)
        {
            "code": "mine-check-letter",
            "owner": "morgan",
            "type": "condition",
            "variable": "player.inventory",
            "isValue": "{type: 'item', code: 'seafarer:letter-morgan', stacksize: 1}",
            "thenJumpTo": "mine-reminder",
            "elseJumpTo": "mine-replace-letter"
        },

        {
            "code": "mine-replace-letter",
            "owner": "morgan",
            "type": "talk",
            "text": [{ "value": "seafarer:dialogue-morgan-replace-letter" }],
            "trigger": "giveitemstack",
            "triggerdata": {
                "type": "item",
                "code": "seafarer:letter-morgan",
                "stacksize": 1
            },
            "jumpTo": "main"
        },

        // Quest Completion
        {
            "code": "mine-deliver-contract",
            "owner": "morgan",
            "type": "talk",
            "trigger": "questDeliver",
            "triggerdata": { "code": "morgan-mine", "objective": "contract" },
            "text": [{ "value": "seafarer:dialogue-morgan-mine-contract-received" }],
            "jumpTo": "mine-complete"
        },
        {
            "code": "mine-complete",
            "owner": "morgan",
            "type": "talk",
            "text": [{ "value": "seafarer:dialogue-morgan-mine-complete" }],
            "jumpTo": "main"
        },

        // Post-Quest
        {
            "code": "rebuilding-done",
            "owner": "morgan",
            "type": "talk",
            "text": [{ "value": "seafarer:dialogue-morgan-rebuilding-done" }],
            "jumpTo": "main"
        }
    ]
}
