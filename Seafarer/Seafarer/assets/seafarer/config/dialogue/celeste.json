            "variable": "player.hasmetceleste",
            "isNotValue": "true",
            "thenJumpTo": "firstmeet",
            "elseJumpTo": "welcomeback"
        },
        {
            "code": "firstmeet",
            "owner": "celeste",
            "type": "talk",
