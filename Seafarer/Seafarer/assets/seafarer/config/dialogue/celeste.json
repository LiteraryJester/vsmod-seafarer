            "text": [{ "value": "seafarer:dialogue-celeste-welcomeback" }],
            "jumpTo": "check-blackbronze-milestone"
        },

        // === Tier-4 milestone: once Tortuga's global rebuilding counter hits
        // 4, Celeste unlocks blackbronze cutlass + shovel stock. One-shot,
        // guarded by entity.celeste-blackbronze-unlocked.
        {
            "code": "check-blackbronze-milestone",
            "owner": "celeste",
            "type": "condition",
            "variable": "entity.celeste-blackbronze-unlocked",
            "isValue": "true",
            "thenJumpTo": "main",
            "elseJumpTo": "check-blackbronze-rebuilding"
        },
        {
            "code": "check-blackbronze-rebuilding",
            "owner": "celeste",
            "type": "condition",
