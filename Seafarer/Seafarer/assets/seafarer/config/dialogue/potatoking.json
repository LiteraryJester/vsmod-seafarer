{
    "components": [
        // === First Meeting ===
        {
            "code": "testhasmet",
            "owner": "potatoking",
            "type": "condition",
            "variable": "player.hasmetpotatoking",
            "isNotValue": "true",
            "thenJumpTo": "firstmeet",
            "elseJumpTo": "welcomeback"
        },
        {
            "code": "firstmeet",
            "owner": "potatoking",
            "type": "talk",
            "setVariables": { "player.hasmetpotatoking": "true" },
            "text": [{ "value": "seafarer:dialogue-potatoking-welcome" }]
        },
        {
            "code": "welcomeback",
            "owner": "potatoking",
            "type": "talk",
            "text": [{ "value": "seafarer:dialogue-potatoking-welcomeback" }],
            "jumpTo": "main"
        },

        // === Main Menu ===
        {
            "code": "main",
            "owner": "player",
            "type": "talk",
            "text": [
                { "value": "dialogue-name", "jumpTo": "name" },
                {
                    "value": "seafarer:dialogue-potatoking-show-letter",
                    "jumpTo": "letter-received",
                    "conditions": [
                        { "variable": "entity.letter-received", "isNotValue": "true" },
                        { "variable": "player.inventory", "isValue": "{type: 'item', code: 'seafarer:letter-morgan', stacksize: 1}" }
                    ]
                },
                {
                    "value": "seafarer:dialogue-potatoking-have-potato",
                    "jumpTo": "potato-deliver",
                    "conditions": [
                        { "variable": "entity.letter-received", "isValue": "true" },
                        { "variable": "entity.contract-given", "isNotValue": "true" },
                        { "variable": "player.inventory", "isValue": "{type: 'item', code: 'game:vegetable-potato', stacksize: 1}" }
                    ]
                },
                {
                    "value": "seafarer:dialogue-potatoking-remind",
                    "jumpTo": "potato-reminder",
                    "conditions": [
                        { "variable": "entity.letter-received", "isValue": "true" },
                        { "variable": "entity.contract-given", "isNotValue": "true" }
                    ]
                }
            ]
        },
        {
            "code": "name",
            "owner": "potatoking",
            "type": "talk",
            "trigger": "revealname",
            "text": [{ "value": "seafarer:dialogue-potatoking-name" }],
            "jumpTo": "main"
        },

        // === Letter from Morgan ===
        {
            "code": "letter-received",
            "owner": "potatoking",
            "type": "talk",
            "setVariables": { "entity.letter-received": "true" },
            "text": [{ "value": "seafarer:dialogue-potatoking-letter-response" }],
            "trigger": "takefrominventory",
            "triggerdata": {
                "type": "item",
                "code": "seafarer:letter-morgan"
            },
            "jumpTo": "potato-quest-start"
        },

        // Potato King gives map to the dungeon
        {
            "code": "potato-quest-start",
            "owner": "potatoking",
            "type": "talk",
            "text": [{ "value": "seafarer:dialogue-potatoking-potato-quest" }],
            "trigger": "giveitemstack",
            "triggerdata": {
                "type": "item",
                "code": "seafarer:map-potato",
                "stacksize": 1
            },
            "jumpTo": "main"
        },

        // Reminder about the potato quest
        {
            "code": "potato-reminder",
            "owner": "potatoking",
            "type": "talk",
            "text": [{ "value": "seafarer:dialogue-potatoking-potato-reminder" }],
            "jumpTo": "main"
        },

        // === Potato Delivery: Give signed contract ===
        {
            "code": "potato-deliver",
            "owner": "potatoking",
            "type": "talk",
            "text": [{ "value": "seafarer:dialogue-potatoking-potato-received" }],
            "trigger": "takefrominventory",
            "triggerdata": {
                "type": "item",
                "code": "game:vegetable-potato"
            },
            "jumpTo": "give-contract"
        },
        {
            "code": "give-contract",
            "owner": "potatoking",
            "type": "talk",
            "setVariables": { "entity.contract-given": "true" },
            "text": [{ "value": "seafarer:dialogue-potatoking-give-contract" }],
            "trigger": "giveitemstack",
            "triggerdata": {
                "type": "item",
                "code": "seafarer:signed-contract",
                "stacksize": 1
            },
            "jumpTo": "main"
        }
    ]
}
