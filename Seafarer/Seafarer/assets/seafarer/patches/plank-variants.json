[
    // ==================================================================
    // Adds "seasoned" and "varnished" variants to all wood-typed blocks
    // that are crafted from planks. This allows plank-seasoned and
    // plank-varnished items to be used in recipes that produce these blocks.
    // ==================================================================

    // --- game:plank (item) ---
    { "op": "add", "path": "/variantgroups/0/states/-", "value": "seasoned",
        "file": "game:itemtypes/resource/plank.json" },
    { "op": "add", "path": "/variantgroups/0/states/-", "value": "varnished",
        "file": "game:itemtypes/resource/plank.json" },
    { "op": "add", "path": "/variantgroups/0/states/-", "value": "unseasoned",
        "file": "game:itemtypes/resource/plank.json" },
    { "op": "replace", "path": "/textures/wood/baseByType",
        "value": {
            "*-seasoned": "seafarer:block/wood/planks/seasoned1",
            "*-varnished": "seafarer:block/wood/planks/varnished1",
            "*-aged": "block/wood/planks/aged/aged1",
            "*-veryaged": "block/wood/planks/aged/veryaged1",
            "*-agedebony": "block/wood/planks/aged/ebony1",
            "*-unseasoned": "block/wood/planks/oak1",
            "*": "block/wood/planks/{wood}1"
        },
        "file": "game:itemtypes/resource/plank.json" },

    // --- game:planks (block) ---
    { "op": "add", "path": "/variantgroups/0/states/-", "value": "seasoned",
        "file": "game:blocktypes/wood/woodtyped/planks.json" },
    { "op": "add", "path": "/variantgroups/0/states/-", "value": "varnished",
        "file": "game:blocktypes/wood/woodtyped/planks.json" },

    // --- game:plankslab ---
