[
    // Disable drying transition on all base-game planks.
    // The saw step instead produces a seafarer:greenplank, which carries
    // its own Dry transition (defined on that item directly).
    {
        "op": "add",
        "path": "/transitionablePropsByType",
        "value": {
            "*": []
        },
        "file": "game:itemtypes/resource/plank.json"
    }
]
