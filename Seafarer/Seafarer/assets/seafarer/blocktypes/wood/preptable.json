{
	code: "preptable",
	class: "BlockPrepTable",
	entityClassByType: {
		"*-left-*": "BlockEntityPrepTable",
		"*-platform-empty-*": "BlockEntityPrepTablePlatform",
		"*-platform-filled-*": "BlockEntityPrepTablePlatform",
		"*-right-*": "BlockEntityPrepTableRight"
	},

	behaviors: [
		{ name: "HorizontalOrientable" }
	],

	variantgroups: [
		{ code: "part", states: ["left", "right", "platform-empty", "platform-filled"] },
		{ code: "side", loadFromProperties: "abstract/horizontalorientation" }
	],

	shapeByType: {
		"*-left-north": { base: "seafarer:block/wood/preptable-left", rotateY: 0 },
		"*-left-east": { base: "seafarer:block/wood/preptable-left", rotateY: 270 },
		"*-left-south": { base: "seafarer:block/wood/preptable-left", rotateY: 180 },
		"*-left-west": { base: "seafarer:block/wood/preptable-left", rotateY: 90 },
		"*-right-north": { base: "seafarer:block/wood/preptable-right", rotateY: 0 },
		"*-right-east": { base: "seafarer:block/wood/preptable-right", rotateY: 270 },
		"*-right-south": { base: "seafarer:block/wood/preptable-right", rotateY: 180 },
		"*-right-west": { base: "seafarer:block/wood/preptable-right", rotateY: 90 },
		"*-platform-empty-north": { base: "seafarer:block/wood/preptable-platform", rotateY: 0 },
		"*-platform-empty-east": { base: "seafarer:block/wood/preptable-platform", rotateY: 270 },
		"*-platform-empty-south": { base: "seafarer:block/wood/preptable-platform", rotateY: 180 },
		"*-platform-empty-west": { base: "seafarer:block/wood/preptable-platform", rotateY: 90 },
		"*-platform-filled-north": { base: "seafarer:block/wood/preptable-platform-filled", rotateY: 0 },
		"*-platform-filled-east": { base: "seafarer:block/wood/preptable-platform-filled", rotateY: 270 },
		"*-platform-filled-south": { base: "seafarer:block/wood/preptable-platform-filled", rotateY: 180 },
		"*-platform-filled-west": { base: "seafarer:block/wood/preptable-platform-filled", rotateY: 90 }
	},

	textures: {
		"wood": { base: "game:block/wood/debarked/oak" },
		"planks": { base: "game:block/wood/planks/oak1" },
		"cuttingboard": { base: "game:block/wood/debarked/baldcypress" },
		"agedwood": { base: "game:block/wood/debarked/aged" }
	},

	drawtype: "json",

	// Only left part in creative (right is auto-placed)
	creativeinventory: {
		"general": ["*-left-north"],
		"seafarer": ["*-left-north"]
	},

	// Selection boxes per part and facing
	// Left part: 0=barrel slot, 1=table body
	// Right part: 0=tool slot, 1=table body
	collisionSelectionBoxesByType: {
		"@*-left-*": [
			{ x1: 0.0, y1: 0.0, z1: 0.0, x2: 1.0, y2: 0.65, z2: 1.0 }
		],
		"@*-right-north": [
			{ x1: 0.3, y1: 0.6, z1: 0.3, x2: 0.9, y2: 1.1, z2: 0.9 },
			{ x1: 0.0, y1: 0.0, z1: 0.0, x2: 1.0, y2: 0.65, z2: 1.0 }
		],
		"@*-right-south": [
			{ x1: 0.1, y1: 0.6, z1: 0.1, x2: 0.7, y2: 1.1, z2: 0.7 },
			{ x1: 0.0, y1: 0.0, z1: 0.0, x2: 1.0, y2: 0.65, z2: 1.0 }
		],
		"@*-right-east": [
			{ x1: 0.1, y1: 0.6, z1: 0.3, x2: 0.7, y2: 1.1, z2: 0.9 },
			{ x1: 0.0, y1: 0.0, z1: 0.0, x2: 1.0, y2: 0.65, z2: 1.0 }
		],
		"@*-right-west": [
			{ x1: 0.3, y1: 0.6, z1: 0.1, x2: 0.9, y2: 1.1, z2: 0.7 },
			{ x1: 0.0, y1: 0.0, z1: 0.0, x2: 1.0, y2: 0.65, z2: 1.0 }
		],
		// Platform: 0=barrel slot, 1=platform body
		"@*-platform-*": [
			{ x1: 0.1, y1: 0.25, z1: 0.1, x2: 0.9, y2: 1.0, z2: 0.9 },
			{ x1: 0.1, y1: 0.0, z1: 0.1, x2: 0.9, y2: 0.25, z2: 0.9 }
		]
	},

	sounds: {
		place: "game:block/planks",
		break: "game:block/planks",
		hit: "game:block/planks"
	},

	resistance: 3,
	lightAbsorption: 0,
	sidesolid: { all: false },
	sideopaque: { all: false },

	// Only left drops the item
	dropsByType: {
		"*-left-*": [{ type: "block", code: "seafarer:preptable-left-north" }],
		"*-right-*": [],
		"*-platform-empty-*": [],
		"*-platform-filled-*": []
	},

	attributes: {
		handbook: {
			groupBy: [ "preptable-*" ]
		}
	},

	guiTransform: {
		origin: { x: 0.5, y: 0.4, z: 0.5 },
		scale: 0.8
	},
	tpHandTransform: {
		translation: { x: -0.75, y: -1, z: -0.675 },
		rotation: { x: 12, y: 15, z: -80 },
		scale: 0.35
	},
	groundTransform: {
		translation: { x: 0, y: 0, z: 0 },
		rotation: { x: 0, y: 0, z: 0 },
		origin: { x: 0.5, y: 0, z: 0.5 },
		scale: 2
	}
}
