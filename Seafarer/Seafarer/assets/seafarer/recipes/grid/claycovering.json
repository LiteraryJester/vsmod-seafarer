// Parallel of game:recipes/grid/claycovering.json for Seafarer's ferrous toolheads.
// We can't extend the vanilla recipe via patches because its T ingredient is `code: "*"`
// which AssetLocation defaults to `game:*` — WildcardUtil.Match short-circuits on the
// domain mismatch before allowedVariants is ever consulted, so adding seafarer codes to
// the allowlist has no effect. A separate recipe with `code: "seafarer:*"` is the correct
// way to register clay-covering for our cross-domain toolheads.
//
// This is the prerequisite for the new 1.22 durability-quench path: clay-cover the head,
// then quench while hot. Without this recipe, only the power-gain quench path is
// reachable for these toolheads.
//
// To enable clay-covering on additional Seafarer toolheads:
//  1. Add the toolhead's ferrous variants here (`<head>-iron`, `-meteoriciron`, `-steel`).
//  2. Make sure the toolhead JSON has `forgable: true` and the Quenchable behavior on
//     ferrous variants — without those, clay-covering does nothing useful.
{
	ingredientPattern: "TC",
	ingredients: {
		"T": { type: "item", code: "seafarer:*", name: "tool", allowedVariants: [
			"bladehead-cutlass-iron",
			"bladehead-cutlass-meteoriciron",
			"bladehead-cutlass-steel",
			"mudrake-head-iron",
			"mudrake-head-meteoriciron",
			"mudrake-head-steel"
		]},
		"C": { type: "item", code: "game:clay-fire" }
	},
	name: "claycovering",
	shapeless: true,
	copyAttributesFrom: 'T',
	width: 2,
	height: 1,
	output: { type: "item", code: "seafarer:{tool}", attributes: { clayCovered: true } }
}
